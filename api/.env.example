APP_ENV=development
SERVER_ADDR=:8080
DATABASE_URL=
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=admin_panel
DB_SSLMODE=disable

JWT_SECRET=change-me-jwt-secret
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_HOURS=720

COOKIE_SECURE=false
COOKIE_DOMAIN=
CORS_ORIGIN=http://localhost:3000

OWNER_EMAIL=
OWNER_PASSWORD=
OWNER_FULL_NAME=Owner
MIGRATIONS_DIR=./migrations

# S3-compatible object storage (Railway bucket)
S3_ENDPOINT=
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=
S3_USE_SSL=true
# Optional public base URL override; when empty API builds URL from endpoint/bucket
S3_PUBLIC_BASE_URL=

# OpenRouter AI summary
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemma-3-27b-it:free

# Microsoft Graph email sending
# Requires an Azure app registration with Microsoft Graph application permission Mail.Send and admin consent.
MICROSOFT_TENANT_ID=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_SENDER_EMAIL=
