---
import { getEntry, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { buttonVariants } from '@/components/ui/button';
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from '@/components/ui/card';

const page = await getEntry('pages', 'home');
if (!page) throw new Error('Missing home page content entry');
const { Content } = await render(page);
---
<BaseLayout title={page.data.title} description={page.data.description}>
  <section class="grid items-center gap-7 lg:grid-cols-[1.05fr_0.95fr]">
    <div class="space-y-6">
      <p class="inline-flex rounded-full border border-primary/30 bg-primary/10 px-4 py-1 text-xs font-bold uppercase tracking-[0.08em] text-amber-900 md:text-sm">
        Vintage Audio, TV, and Computer Repair
      </p>
      <h1 class="max-w-xl text-4xl leading-tight md:text-5xl">{page.data.heading ?? page.data.title}</h1>
      <p class="max-w-xl text-lg text-amber-900/90 md:text-xl">Professional diagnostics, honest repair guidance, and careful restoration for classic and modern equipment.</p>
      <div class="flex flex-wrap gap-3">
        <a href="/request-a-pickup" class={buttonVariants({ variant: 'default', size: 'lg' })}>Request Free Pickup</a>
        <a href="/items-for-sale" class={buttonVariants({ variant: 'outline', size: 'lg' })}>Browse Restored Gear</a>
      </div>
      <div class="grid gap-3 sm:grid-cols-3">
        <div class="rounded-2xl border border-amber-900/20 bg-amber-50/85 p-4">
          <p class="text-xs uppercase tracking-[0.08em] text-amber-700">Toronto & GTA</p>
          <p class="text-2xl font-bold text-amber-950">(416) 923-3777</p>
        </div>
        <div class="rounded-2xl border border-amber-900/20 bg-amber-50/85 p-4">
          <p class="text-xs uppercase tracking-[0.08em] text-amber-700">Newmarket</p>
          <p class="text-2xl font-bold text-amber-950">(905) 235-2226</p>
        </div>
        <div class="rounded-2xl border border-amber-900/20 bg-amber-50/85 p-4">
          <p class="text-xs uppercase tracking-[0.08em] text-amber-700">Service Legacy</p>
          <p class="text-2xl font-bold text-amber-950">Since 1955</p>
        </div>
      </div>
    </div>

    <div class="relative">
      <div class="absolute -inset-4 -z-10 rounded-[2.4rem] bg-primary/20 blur-3xl"></div>
      <img
        class="h-[500px] w-full rounded-[2rem] border border-amber-900/20 object-cover shadow-soft"
        src="https://lirp.cdn-website.com/f68022c3/dms3rep/multi/opt/20230328_124107-1920w.jpg"
        alt="Humphrey's repair workbench with vintage audio equipment"
        loading="eager"
      />
      <div class="absolute bottom-5 left-5 right-5 rounded-2xl border border-amber-100/40 bg-amber-950/70 p-4 backdrop-blur-sm">
        <p class="text-xs uppercase tracking-[0.08em] text-amber-200">Trusted by local customers</p>
        <p class="mt-1 text-lg font-bold text-amber-50">Fast diagnostics and clear repair options before any major work begins.</p>
      </div>
    </div>
  </section>

  <section class="mt-8 grid gap-4 md:grid-cols-3">
    <Card className="border-amber-900/20 bg-amber-50/80 shadow-soft transition-shadow hover:shadow-2xl">
      <CardHeader>
        <CardTitle>Audio Specialists</CardTitle>
        <CardDescription>Receivers, amplifiers, turntables, cassette decks, and reel-to-reel systems.</CardDescription>
      </CardHeader>
    </Card>
    <Card className="border-amber-900/20 bg-amber-50/80 shadow-soft transition-shadow hover:shadow-2xl">
      <CardHeader>
        <CardTitle>Pickup Convenience</CardTitle>
        <CardDescription>Free pickup and delivery in Toronto and the GTA for qualifying jobs.</CardDescription>
      </CardHeader>
    </Card>
    <Card className="border-amber-900/20 bg-amber-50/80 shadow-soft transition-shadow hover:shadow-2xl">
      <CardHeader>
        <CardTitle>Restoration Expertise</CardTitle>
        <CardDescription>Practical troubleshooting and restoration experience across generations of equipment.</CardDescription>
      </CardHeader>
    </Card>
  </section>

  <section class="mt-8 grid gap-6 lg:grid-cols-[1.1fr_0.9fr]">
    <article class="rounded-3xl border border-amber-900/20 bg-amber-50/80 p-6 md:p-8">
      <h2 class="text-3xl">Full-Service Repair and Restoration</h2>
      <div class="marketing-prose mt-3">
        <Content />
      </div>
    </article>

    <Card className="h-fit border-amber-900/15 bg-gradient-to-br from-amber-900 via-amber-900 to-amber-800 text-amber-50">
      <CardHeader>
        <CardTitle className="text-amber-50">Need a Fast Repair Answer?</CardTitle>
        <CardDescription className="text-amber-100/85">
          Share make, model, and issue details. We will help you plan the best next step.
        </CardDescription>
      </CardHeader>
      <CardContent>
        <div class="space-y-3 text-sm text-amber-100">
          <p>Email: humphreys.repair@rogers.com</p>
          <p>Toronto & GTA: (416) 923-3777</p>
          <p>Newmarket: (905) 235-2226</p>
          <p>Address: 16610 Bayview Ave, Unit #7, Newmarket</p>
        </div>
        <a href="/contact" class={`${buttonVariants({ variant: 'default', size: 'default' })} mt-6`}>Contact the Team</a>
      </CardContent>
    </Card>
  </section>
</BaseLayout>
